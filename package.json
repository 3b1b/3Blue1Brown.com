    "@phosphor-icons/react": "^2.1.10",
    "@react-router/node": "^8.2.0",
    "@react-three/fiber": "9.6.1",
    "@reactuses/core": "^6.4.0",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "d3": "^7.9.0",
    "embla-carousel-react": "9.0.0-rc02",
    "fuse.js": "^7.5.0",
    "glsl-canvas-js": "git+https://github.com/InfiniteLoopGameDev/glsl-canvas.git#master",
    "gsap": "^3.15.0",
    "isbot": "^5.2.1",
    "jotai": "^2.20.2",
    "lodash-es": "^4.18.1",
    "react": "^19.2.7",
    "react-children-utilities": "^2.10.0",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-p5": "^1.4.1",
    "react-router": "^8.2.0",
    "react-schemaorg": "^2.0.1",
    "three": "0.185.1",
    "ua-parser-js": "^2.0.10",
    "vimeo-video-element": "^1.7.2",
    "youtube-video-element": "^1.9.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@mdx-js/rollup": "^3.1.1",
    "@playwright/test": "^1.61.1",
    "@react-router/dev": "^8.2.0",
    "@tailwindcss/vite": "^4.3.3",
    "@types/d3": "^7.4.3",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26",
    "@types/p5": "^1.7.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-mdx": "^3.8.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
