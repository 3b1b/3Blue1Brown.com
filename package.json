    "@reactuses/core": "^6.3.1",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "d3": "^7.9.0",
    "embla-carousel-react": "9.0.0-rc02",
    "fuse.js": "^7.3.0",
    "glsl-canvas-js": "git+https://github.com/InfiniteLoopGameDev/glsl-canvas.git#master",
    "gsap": "^3.15.0",
    "isbot": "^5.1.40",
    "jotai": "^2.19.1",
    "lodash-es": "^4.18.1",
    "react": "^19.2.5",
    "react-children-utilities": "^2.10.0",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-p5": "^1.4.1",
    "react-router": "^7.15.0",
    "react-schemaorg": "^2.0.1",
    "three": "0.184.0",
    "ua-parser-js": "^2.0.9",
    "youtube-video-element": "^1.9.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
